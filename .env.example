# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-in-production

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
SESSION_SECRET=change-me-in-production

# ── Google OAuth (calendar + sign-in) ────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost/api/auth/callback
# Production example: GOOGLE_REDIRECT_URL=https://app.example.com/api/auth/callback

# ── Microsoft OAuth (Outlook calendar + sign-in) ─────────────────────────────
# https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URL=http://localhost/api/auth/microsoft/callback

# ── Zoom OAuth (conferencing) ─────────────────────────────────────────────────
# https://marketplace.zoom.us/develop/create
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URL=http://localhost/api/auth/zoom/callback

# ── LLM provider credentials ─────────────────────────────────────────────────
# OpenAI, Anthropic, AWS Bedrock, Azure OpenAI, Vertex AI, and Ollama credentials
# are configured per-user in the Settings page and stored in the database.
# No env vars needed here — users bring their own API keys.

# ── Slack OAuth (meeting briefs + daily recap) ───────────────────────────────
# https://api.slack.com/apps → Create App → OAuth & Permissions
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost/api/integrations/slack/callback

# ── Notion OAuth (meeting briefs) ─────────────────────────────────────────────
# https://www.notion.so/my-integrations → New Integration → OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost/api/integrations/notion/callback

# ── MCP Server ───────────────────────────────────────────────────────────────
# Optional bearer token to protect the SSE endpoint (leave empty for open access)
MCP_AUTH_TOKEN=

# ── TLS (production only) ────────────────────────────────────────────────────
# Path to directory containing Let's Encrypt certificates
TLS_CERT_DIR=/etc/letsencrypt
